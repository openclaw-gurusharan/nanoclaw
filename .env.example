# Required: Claude Code OAuth token (primary auth path)
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-xxxxxxxxxxxxxxxx

# Required: single GitHub token used by all lanes/workers.
# Runtime maps this to both GITHUB_TOKEN and GH_TOKEN inside containers.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional API fallback (used only when OAuth fallback is enabled)
OAUTH_API_FALLBACK_ENABLED=false
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxx

# Used only when OAUTH_API_FALLBACK_ENABLED=true
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional model override for API-key lane/fallback
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-5

# Runtime profile (default mission_core).
# mission_core: fixed lanes + strict dispatch/completion, minimal control-plane load.
# ops_extended: enables scheduler/steering/dynamic group management paths.
NANOCLAW_RUNTIME_PROFILE=mission_core

# Optional feature gates (default follows profile if unset)
# NANOCLAW_ENABLE_SCHEDULER=false
# NANOCLAW_ENABLE_WORKER_STEERING=false
# NANOCLAW_ENABLE_DYNAMIC_GROUP_REGISTRATION=false
# NANOCLAW_ENABLE_CONTROL_PLANE_SNAPSHOTS=false
# EVENT_BRIDGE_ENABLED=false

# Runtime timeout controls
IDLE_TIMEOUT=300000
CONTAINER_TIMEOUT=1800000
CONTAINER_NO_OUTPUT_TIMEOUT=720000
WORKER_MIN_NO_OUTPUT_TIMEOUT_MS=900000
SHUTDOWN_DRAIN_MS=600000
ANDY_BUSY_PREEMPT_MS=90000
ANDY_BUSY_ACK_COOLDOWN_MS=180000
ANDY_ERROR_NOTICE_COOLDOWN_MS=180000

# WhatsApp reconnect backoff/cooldown controls
WA_RECONNECT_BASE_DELAY_MS=1000
WA_RECONNECT_MAX_DELAY_MS=30000
WA_RECONNECT_JITTER_MS=750
WA_RECONNECT_BURST_WINDOW_MS=600000
WA_RECONNECT_BURST_THRESHOLD=15
WA_RECONNECT_COOLDOWN_MS=60000
